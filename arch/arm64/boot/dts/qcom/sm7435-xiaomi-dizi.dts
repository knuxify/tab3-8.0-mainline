/dts-v1/;

#include <dt-bindings/regulator/qcom,rpmh-regulator.h>

#include "sm7435.dtsi"
#include "pmk8350.dtsi"
#include "pm6450.dtsi"
#include "pm6150l.dtsi"

/ {
	model = "Xiaomi Redmi Pad Pro/POCO Pad";
	compatible = "xiaomi,dizi", "qcom,sm7435";

	chassis-type = "tablet";

	qcom,msm-id = <537 0x10000>; // TODO: are the other values needed?
	qcom,board-id = <0x2000b 1>;
};

&pm6150l_flash {
	status = "okay";

	// TODO: LED subnodes
};

/*
 * Other PMICs:
 * - pmr735a@6, unused
 * - pm7250b@8 and @9, unused (vibrator node is on, but device has no vibrator)
 */

&apps_rsc {
	regulators-1 {
		compatible = "qcom,pm6450-rpmh-regulators";
		qcom,pmic-id = "b";

		pm6450_s6: smps6 {
			regulator-name = "pm6450_s6";
			regulator-min-microvolt = <1010000>;
			regulator-max-microvolt = <1170000>;
		};

		pm6450_s7: smps7 {
			regulator-name = "pm6450_s7";
			regulator-min-microvolt = <880000>;
			regulator-max-microvolt = <1174000>;
		};

		pm6450_s8: smps8 {
			regulator-name = "pm6450_s8";
			regulator-min-microvolt = <1224000>;
			regulator-max-microvolt = <1654000>;
		};

		pm6450_s9: smps9 {
			regulator-name = "pm6450_s9";
			regulator-min-microvolt = <850000>;
			regulator-max-microvolt = <2208000>;
		};

		pm6450_l1: ldo1 {
			regulator-name = "pm6450_l1";
			regulator-min-microvolt = <300000>;
			regulator-max-microvolt = <650000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l3: ldo3 {
			regulator-name = "pm6450_l3";
			regulator-min-microvolt = <870000>;
			regulator-max-microvolt = <970000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l4: ldo4 {
			regulator-name = "pm6450_l4";
			regulator-min-microvolt = <530000>;
			regulator-max-microvolt = <864000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l5: ldo5 {
			regulator-name = "pm6450_l5";
			regulator-min-microvolt = <830000>;
			regulator-max-microvolt = <920000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l6: ldo6 {
			regulator-name = "pm6450_l6";
			regulator-min-microvolt = <751000>;
			regulator-max-microvolt = <824000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l7: ldo7 {
			regulator-name = "pm6450_l7";
			regulator-min-microvolt = <830000>;
			regulator-max-microvolt = <920000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l8: ldo8 {
			regulator-name = "pm6450_l8";
			regulator-min-microvolt = <870000>;
			regulator-max-microvolt = <970000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l10: ldo10 {
			regulator-name = "pm6450_l10";
			regulator-min-microvolt = <824000>;
			regulator-max-microvolt = <950000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l11: ldo11 {
			regulator-name = "pm6450_l11";
			regulator-min-microvolt = <348000>;
			regulator-max-microvolt = <888000>;
		};

		pm6450_l12: ldo12 {
			regulator-name = "pm6450_l12";
			regulator-min-microvolt = <1080000>;
			regulator-max-microvolt = <1240000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l13: ldo13 {
			regulator-name = "pm6450_l13";
			regulator-min-microvolt = <1080000>;
			regulator-max-microvolt = <1304000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l14: ldo14 {
			regulator-name = "pm6450_l14";
			regulator-min-microvolt = <1150000>;
			regulator-max-microvolt = <1304000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

		pm6450_l15: ldo15 {
			regulator-name = "pm6450_l15";
			regulator-min-microvolt = <1080000>;
			regulator-max-microvolt = <1304000>;
			regulator-initial-mode = <RPMH_REGULATOR_MODE_HPM>;
		};

